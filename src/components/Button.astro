---
type Variant = 'primary' | 'secondary' | 'ghost' | 'whatsapp' | 'link' | 'danger' | 'onColorSolid' | 'onColorOutline';
type Size = 'sm' | 'md' | 'lg';

interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  target?: string;
  rel?: string;
  fullWidth?: boolean;
  class?: string;
  'aria-label'?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  target,
  rel,
  fullWidth = false,
  class: className = '',
  'aria-label': ariaLabel,
  ...rest
} = Astro.props;

const sizeClasses: Record<Size, string> = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-5 py-3 text-sm',
  lg: 'px-8 py-4 text-sm',
};

const variantClasses: Record<Variant, string> = {
  primary:
    'bg-brand-accent text-white font-extrabold shadow-lg shadow-brand-accent/25 hover:bg-brand-accent/90 hover:shadow-xl hover:-translate-y-px focus-visible:ring-brand-accent/60',
  secondary:
    'border border-brand-border bg-brand-surface text-brand-primary font-extrabold hover:bg-brand-background focus-visible:ring-brand-accent/40',
  ghost:
    'text-brand-secondary hover:text-brand-accent font-bold focus-visible:ring-brand-accent/50',
  whatsapp:
    'flex-1 basis-0 min-w-0 bg-green-500 hover:bg-green-600 text-white font-bold py-4 shadow-lg shadow-green-500/25 hover:shadow-xl hover:-translate-y-px focus-visible:ring-green-500/60',
  link:
    'inline-flex items-center gap-1.5 text-sm font-bold text-brand-accent hover:text-brand-accent/70 focus-visible:ring-brand-accent/50',
  danger:
    'border border-red-500/30 bg-red-500/10 text-red-500 font-bold hover:bg-red-500 hover:text-white focus-visible:ring-red-500/50',
  onColorSolid:
    'bg-white text-blue-700 font-extrabold shadow-lg hover:bg-slate-50 hover:text-blue-800 hover:shadow-xl hover:-translate-y-px focus-visible:ring-white/60',
  onColorOutline:
    'bg-transparent border border-white/25 text-white font-extrabold hover:bg-white/10 focus-visible:ring-white/40',
};

const baseClasses =
  'inline-flex items-center justify-center gap-2 rounded-xl transition-all duration-200 cursor-pointer focus-visible:outline-none focus-visible:ring-2 active:scale-[0.98] select-none';

const Tag = href ? 'a' : 'button';
const widthClass = fullWidth ? 'w-full' : '';

const finalClass = [
  baseClasses,
  sizeClasses[size],
  variantClasses[variant],
  widthClass,
  className,
].filter(Boolean).join(' ');
---

<Tag
  class={finalClass}
  href={href}
  type={!href ? type : undefined}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  {...rest}
>
  <slot />
</Tag>
