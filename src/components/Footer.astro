---
import Icon from './Icon.astro';
import site from '../config/site';
---

<footer class="w-full border-t border-brand-border bg-brand-surface text-brand-primary py-14 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-10">

    <div class="space-y-4 md:col-span-1">
      <a href="/" class="flex items-center gap-3 group w-fit focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded-lg">
        <div class="w-8 h-8 rounded-lg bg-brand-accent flex items-center justify-center text-white font-black text-sm shadow-md shadow-brand-accent/30 group-hover:scale-105 transition-transform duration-200">
          {site.brand.shortName}
        </div>
        <span class="font-extrabold text-xl tracking-tight text-brand-primary">{site.brand.name}</span>
      </a>
      <p class="text-brand-secondary text-sm leading-relaxed max-w-xs">
        {site.brand.tagline}
      </p>
      <div class="flex items-center gap-4 text-brand-secondary pt-1">
        {site.social.map(s => (
          <a
            href={s.href}
            aria-label={s.label}
            class="hover:text-brand-accent transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded"
          >
            <span class="text-sm font-bold">{s.label}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="space-y-4">
      <h3 class="text-xs font-black uppercase tracking-widest text-brand-secondary">Navegación</h3>
      <ul class="space-y-2.5 text-sm">
        {site.navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="text-brand-secondary hover:text-brand-accent transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="space-y-4">
      <h3 class="text-xs font-black uppercase tracking-widest text-brand-secondary">Contacto</h3>
      <ul class="space-y-3 text-sm text-brand-secondary" role="list">
        {site.contact.emails.map(email => (
          <li class="flex items-start gap-3">
            <Icon name="mail" class="w-4 h-4 mt-0.5 text-brand-accent shrink-0" />
            <span>{email}</span>
          </li>
        ))}
        <li class="flex items-start gap-3">
          <Icon name="phone" class="w-4 h-4 mt-0.5 text-brand-accent shrink-0" />
          <span>{site.contact.phoneDisplay}</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="location" class="w-4 h-4 mt-0.5 text-brand-accent shrink-0" />
          <span>{site.contact.address}</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-6 mt-12 pt-6 border-t border-brand-border flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-brand-secondary/60">
    <p>&copy; {new Date().getFullYear()} {site.brand.name}. Todos los derechos reservados.</p>
    <p class="flex items-center gap-1.5">
      <span aria-hidden="true">⚡</span> Powered by Astro &amp; TinaCMS
    </p>
  </div>
</footer>
