---
import ThemeToggle from './vue/ThemeToggle.vue';
import BadgeCart from './vue/BadgeCart.vue';
import CartDrawer from './vue/CartDrawer.vue';
import MobileMenu from './vue/MobileMenu.vue';
import site from '../config/site';

const currentPath = Astro.url.pathname;
const isCurrent = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header
  class="fixed top-4 left-1/2 -translate-x-1/2 w-[90%] max-w-5xl z-50 h-16 border border-brand-border bg-brand-surface/85 dark:bg-brand-surface/90 backdrop-blur-lg rounded-2xl shadow-lg shadow-brand-accent/5 flex items-center justify-between px-4 sm:px-6"
>
  <a
    href="/"
    class="flex items-center gap-3 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded-lg shrink-0"
    aria-label={`${site.brand.name} - Inicio`}
  >
    <div class="w-8 h-8 rounded-lg bg-brand-accent flex items-center justify-center text-white font-black tracking-wider text-sm shadow-md shadow-brand-accent/30 group-hover:scale-105 transition-transform duration-200">
      {site.brand.shortName}
    </div>
    <span class="font-extrabold text-lg tracking-tight text-brand-primary hidden sm:inline">
      {site.brand.name}
    </span>
  </a>

  <nav class="hidden md:block" aria-label="Navegación principal">
    <ul role="list" class="flex items-center gap-1">
      {site.navLinks.map((link) => {
        const active = isCurrent(link.href);
        return (
          <li>
            <a
              href={link.href}
              aria-current={active ? 'page' : undefined}
              class:list={[
                'relative px-3 py-2 text-sm font-bold transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded-md group/nav',
                active
                  ? 'text-brand-accent'
                  : 'text-brand-secondary hover:text-brand-accent',
              ]}
            >
              {link.label}
              <span
                aria-hidden="true"
                class:list={[
                  'absolute left-3 right-3 -bottom-0.5 h-0.5 rounded-full bg-brand-accent origin-left transition-transform duration-300 ease-out',
                  active ? 'scale-x-100' : 'scale-x-0 group-hover/nav:scale-x-100',
                ]}
              ></span>
            </a>
          </li>
        );
      })}
    </ul>
  </nav>

  <div class="flex items-center gap-2">
    <BadgeCart client:load />
    <ThemeToggle client:load transition:persist="theme-toggle" />
    <a
      href="/contacto"
      class="hidden md:inline-flex items-center gap-1.5 px-4 py-2 rounded-full bg-brand-accent text-white text-sm font-bold shadow-sm shadow-brand-accent/25 hover:bg-brand-accent/90 hover:shadow-md hover:-translate-y-px transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/60"
    >
      Contactar
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </a>
    <button
      type="button"
      onclick="window.dispatchEvent(new CustomEvent('open-mobile-menu'))"
      aria-label="Abrir menú"
      class="md:hidden cursor-pointer p-2 rounded-xl border border-brand-border hover:bg-brand-background text-brand-primary transition-all duration-200 select-none active:scale-95 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 flex items-center gap-1.5"
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-5 h-5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <span class="text-xs font-bold">Menú</span>
    </button>
  </div>
</header>

<CartDrawer client:only="vue" />

<MobileMenu client:only="vue">
  {site.navLinks.map((link) => {
    const active = isCurrent(link.href);
    return (
      <li>
        <a
          href={link.href}
          aria-current={active ? 'page' : undefined}
          onclick="window.dispatchEvent(new CustomEvent('close-mobile-menu'))"
          class:list={[
            'flex items-center justify-between px-4 py-3 text-base font-bold rounded-xl transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50',
            active
              ? 'bg-brand-accent/10 text-brand-accent'
              : 'text-brand-primary hover:bg-brand-background',
          ]}
        >
          {link.label}
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
          </svg>
        </a>
      </li>
    );
  })}
  <li class="pt-2">
    <a
      href="/contacto"
      onclick="window.dispatchEvent(new CustomEvent('close-mobile-menu'))"
      class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-xl bg-brand-accent text-white text-base font-bold shadow-sm hover:bg-brand-accent/90 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/60"
    >
      Contactar
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
      </svg>
    </a>
  </li>
</MobileMenu>
