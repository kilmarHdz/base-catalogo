---
interface Props {
  href?: string;
  class?: string;
  imageAspect?: 'square' | '4/3' | '16/9';
  transitionName?: string;
  imageUrl?: string | null;
  imageAlt?: string;
}

const {
  href,
  class: className = '',
  imageAspect = '4/3',
  transitionName,
  imageUrl,
  imageAlt = '',
} = Astro.props;

const aspectClass = {
  square: 'aspect-square',
  '4/3': 'aspect-[4/3]',
  '16/9': 'aspect-video',
}[imageAspect];

const Tag = href ? 'a' : 'article';
const wrapperProps = href
  ? { href, class: `group block ${className}` }
  : { class: `group block ${className}` };
---

<Tag {...wrapperProps}>
  <div class="bg-brand-surface border border-brand-border hover:border-brand-accent/25 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col h-full">
    <div class={`relative overflow-hidden bg-brand-background ${aspectClass}`}>
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt}
          width="400"
          height="300"
          loading="lazy"
          transition:name={transitionName}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-brand-secondary/20" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-14 h-14">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375 0 0 1-.75 0 .375 0 0 1 .75 0z" />
          </svg>
        </div>
      )}
      <slot name="badges" />
    </div>
    <div class="flex flex-col flex-grow p-5">
      <slot />
    </div>
    <slot name="footer" />
  </div>
</Tag>
