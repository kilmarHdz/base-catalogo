  class?: string;
  'aria-hidden'?: boolean | 'true' | 'false';
}

const { name, class: className = 'w-4 h-4', 'aria-hidden': ariaHidden = 'true' } = Astro.props;
const aria = ariaHidden === 'false' ? undefined : 'true';
