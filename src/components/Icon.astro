---
type IconName = 'chevron-right' | 'chevron-left' | 'arrow-right' | 'arrow-left' | 'arrow-up-right' | 'check' | 'plus' | 'minus' | 'close' | 'menu' | 'sun' | 'moon' | 'cart' | 'search' | 'mail' | 'phone' | 'location' | 'trash' | 'info';

interface Props {
