---
import LayoutPrincipal from '../../layouts/LayoutPrincipal.astro';
import Button from '../../components/Button.astro';
import Badge from '../../components/Badge.astro';
import Icon from '../../components/Icon.astro';
import CatalogoFiltros from '../../components/vue/CatalogoFiltros.vue';
import client from '../../../tina/__generated__/client';

const response = await client.queries.productConnection({ first: 500 });
const productos = response.data.productConnection.edges
  ?.map((edge) => edge?.node)
  .filter((node): node is NonNullable<typeof node> => node !== null) ?? [];
---

<LayoutPrincipal
  title="Catálogo de Productos"
  description="Explora nuestro catálogo completo. Filtra por categoría, busca por nombre o SKU, y añade productos al carrito para solicitar cotización."
>
  <main class="max-w-6xl mx-auto py-12 px-6">
    <header class="mb-10">
      <Badge variant="tag" class="px-4 py-1.5 mb-4">Gama Completa</Badge>
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <h1 class="text-4xl md:text-5xl font-black tracking-tight text-brand-primary text-balance">
            Catálogo de Productos
          </h1>
          <p class="text-brand-secondary text-lg mt-2 max-w-xl leading-relaxed">
            Filtra y busca entre toda nuestra gama. Encuentra el producto ideal y solicítalo sin compromiso.
          </p>
        </div>
        <Button variant="primary" size="md" href="/contacto">
          Solicitar Cotización
          <Icon name="chevron-right" class="w-4 h-4" />
        </Button>
      </div>
    </header>

    <CatalogoFiltros client:load transition:persist="catalogo-filtros" productos={productos as any} />
  </main>
</LayoutPrincipal>
