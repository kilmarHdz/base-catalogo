---
import LayoutPrincipal from '../../layouts/LayoutPrincipal.astro';
import AddToCartButton from '../../components/vue/AddToCartButton.vue';
import client from '../../../tina/__generated__/client';

export async function getStaticPaths() {
  const response = await client.queries.productConnection();
  return response.data.productConnection.edges?.map((edge) => ({
    params: { slug: edge?.node?._sys.relativePath.replace(/\.json$/, '') },
  })) || [];
}

const { slug } = Astro.params;

const response = await client.queries.product({
  relativePath: `${slug}.json`,
});
const producto = response.data.product;

const whatsappNumber = "34900123456";
const messageText = `¡Hola! Me interesa obtener más información sobre el siguiente producto:\n\n*${producto.title}*\n*SKU:* ${producto.sku}\n*Categoría:* ${producto.category || 'General'}\n\n¿Me podrían ayudar?`;
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(messageText)}`;
---

<LayoutPrincipal
  title={`${producto.title} - Ficha de Producto`}
  description={producto.description ?? `Ficha técnica de ${producto.title}. SKU: ${producto.sku}.`}
>
  <main class="max-w-5xl mx-auto py-10 px-6">

    <!-- Breadcrumb -->
    <nav aria-label="Ruta de navegación" class="flex items-center gap-1.5 text-xs text-brand-secondary mb-8 flex-wrap">
      <a href="/" class="hover:text-brand-accent transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded">Inicio</a>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-secondary/40 shrink-0" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
      <a href="/productos" class="hover:text-brand-accent transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded">Catálogo</a>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-secondary/40 shrink-0" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
      {producto.category && (
        <>
          <span class="text-brand-secondary/60">{producto.category}</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3 text-brand-secondary/40 shrink-0" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
        </>
      )}
      <span class="text-brand-primary font-semibold truncate max-w-[200px]">{producto.title}</span>
    </nav>

    <!-- Product Card -->
    <article class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 bg-brand-surface border border-brand-border rounded-3xl p-6 md:p-10 shadow-sm">

      <!-- Image -->
      <div class="md:col-span-5 flex flex-col gap-4">
        <div class="relative overflow-hidden rounded-2xl bg-brand-background aspect-square border border-brand-border flex items-center justify-center group">
          {producto.mainImage ? (
            <img
              src={producto.mainImage}
              alt={producto.title}
              width="500"
              height="500"
              fetchpriority="high"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          ) : (
            <div class="text-brand-secondary/20 flex flex-col items-center gap-3" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-20 h-20">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375 0 11-.75 0 .375 0 01.75 0z" />
              </svg>
              <span class="text-xs">Sin imagen</span>
            </div>
          )}
          {producto.featured && (
            <span class="absolute top-4 left-4 bg-amber-400 text-amber-900 text-xs font-black tracking-wider uppercase px-3 py-1.5 rounded-full shadow-md">
              ⭐ Destacado
            </span>
          )}
        </div>

        <!-- Trust badges below image -->
        <div class="grid grid-cols-3 gap-2">
          {[
            { icon: "✅", label: "Calidad certificada" },
            { icon: "🚚", label: "Entrega 24h" },
            { icon: "💬", label: "Asesoría gratis" },
          ].map(badge => (
            <div class="flex flex-col items-center gap-1 p-3 bg-brand-background border border-brand-border rounded-xl text-center">
              <span class="text-base" aria-hidden="true">{badge.icon}</span>
              <span class="text-[9px] font-bold text-brand-secondary leading-tight">{badge.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Details -->
      <div class="md:col-span-7 flex flex-col gap-6">

        <!-- Header -->
        <div class="space-y-3">
          <span class="inline-block text-xs font-black tracking-widest uppercase text-brand-accent bg-brand-accent/10 px-3 py-1 rounded-full border border-brand-accent/20">
            {producto.category || 'Categoría General'}
          </span>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-brand-primary text-balance leading-tight">
            {producto.title}
          </h1>
          <div class="flex items-center gap-2">
            <span class="text-xs font-mono text-brand-secondary bg-brand-background px-3 py-1.5 rounded-lg border border-brand-border">
              SKU: {producto.sku}
            </span>
          </div>
        </div>

        <!-- Description -->
        <div class="border-t border-brand-border pt-5">
          <h2 class="text-[10px] font-black uppercase tracking-widest text-brand-secondary mb-2">Descripción</h2>
          <p class="text-brand-secondary text-sm leading-relaxed">
            {producto.description}
          </p>
        </div>

        <!-- Specs table -->
        {producto.specs && producto.specs.length > 0 && (
          <div class="border-t border-brand-border pt-5">
            <h2 class="text-[10px] font-black uppercase tracking-widest text-brand-secondary mb-3">Especificaciones Técnicas</h2>
            <div class="overflow-hidden rounded-xl border border-brand-border">
              <table class="w-full text-left text-sm border-collapse">
                <tbody>
                  {producto.specs.map((spec, index) => (
                    <tr class={index % 2 === 0 ? 'bg-brand-background/50' : 'bg-brand-surface'}>
                      <td class="px-4 py-3 font-semibold text-brand-secondary border-r border-brand-border w-2/5 text-xs">
                        {spec?.key}
                      </td>
                      <td class="px-4 py-3 text-brand-primary font-medium text-sm">
                        {spec?.value}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}

        <!-- CTAs -->
        <div class="border-t border-brand-border pt-5 flex flex-col sm:flex-row gap-3 mt-auto">
          <AddToCartButton
            client:load
            title={producto.title}
            sku={producto.sku}
            mainImage={producto.mainImage}
            category={producto.category}
          />
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 sm:flex-none sm:px-6 border border-brand-border bg-brand-background hover:bg-brand-surface hover:border-brand-accent/30 text-brand-primary font-bold text-center py-3.5 rounded-xl shadow-sm transition-all duration-200 flex items-center justify-center gap-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 text-sm"
          >
            <svg class="w-4 h-4 fill-current text-green-500 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Consultar por WhatsApp
          </a>
        </div>

      </div>
    </article>

    <!-- Back link -->
    <div class="mt-8">
      <a
        href="/productos"
        class="inline-flex items-center gap-2 text-sm font-semibold text-brand-secondary hover:text-brand-accent transition-colors duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform duration-200" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
        Volver al catálogo
      </a>
    </div>
  </main>
</LayoutPrincipal>
