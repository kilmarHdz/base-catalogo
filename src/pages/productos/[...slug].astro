---
import LayoutPrincipal from '../../layouts/LayoutPrincipal.astro';
import Button from '../../components/Button.astro';
import Badge from '../../components/Badge.astro';
import Icon from '../../components/Icon.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import JsonLd from '../../components/JsonLd.astro';
import AddToCartButton from '../../components/vue/AddToCartButton.vue';
import client from '../../../tina/__generated__/client';
import site from '../../config/site';
import { productSlug } from '../../types/product';

export async function getStaticPaths() {
  const response = await client.queries.productConnection();
  return response.data.productConnection.edges
    ?.map((edge) => edge?.node)
    .filter((node): node is NonNullable<typeof node> => node !== null)
    .map((node) => ({
      params: { slug: productSlug(node) },
    })) ?? [];
}

const { slug } = Astro.params;

const response = await client.queries.product({
  relativePath: `${slug}.json`,
});
const producto = response.data.product;

if (!producto) {
  return Astro.redirect('/404');
}

const messageText = `${site.whatsapp.productInquiryPrefix}\n\n*${producto.title}*\n*SKU:* ${producto.sku}\n*Categoría:* ${producto.category || 'General'}\n\n¿Me podrían ayudar?`;
const whatsappUrl = `https://wa.me/${site.whatsapp.number}?text=${encodeURIComponent(messageText)}`;
const transitionName = `product-image-${producto.sku}`;

const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: producto.title,
  description: producto.description ?? undefined,
  sku: producto.sku,
  category: producto.category ?? undefined,
  image: producto.mainImage ?? undefined,
  brand: {
    '@type': 'Brand',
    name: site.brand.name,
  },
};
---

<LayoutPrincipal
  title={`${producto.title} - ${site.brand.name}`}
  description={producto.description ?? `${producto.title} · SKU: ${producto.sku}`}
>
  <JsonLd data={productJsonLd} />

  <main class="max-w-5xl mx-auto pt-28 pb-10 px-6">
    <Breadcrumb
      items={[
        { label: 'Inicio', href: '/' },
        { label: 'Catálogo', href: '/productos' },
        ...(producto.category ? [{ label: producto.category }] : []),
        { label: producto.title },
      ]}
      class="mb-8"
    />

    <article class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 bg-brand-surface border border-brand-border rounded-3xl p-6 md:p-10 shadow-sm">
      <div class="md:col-span-5 flex flex-col gap-4">
        <div class="relative overflow-hidden rounded-2xl bg-brand-background aspect-square border border-brand-border flex items-center justify-center group">
          {producto.mainImage ? (
            <img
              src={producto.mainImage}
              alt={producto.title}
              width="500"
              height="500"
              fetchpriority="high"
              transition:name={transitionName}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          ) : (
            <div class="text-brand-secondary/20 flex flex-col items-center gap-3" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-20 h-20">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.0 0 1-.75 0 .375.375 0 0 1 .75 0z" />
              </svg>
              <span class="text-xs">Sin imagen</span>
            </div>
          )}
          {producto.featured && (
            <Badge variant="featured" class="top-4 left-4">⭐ Destacado</Badge>
          )}
        </div>

        <div class="grid grid-cols-3 gap-2">
          {[
            { icon: "✅", label: "Calidad" },
            { icon: "🚚", label: "Envío rápido" },
            { icon: "💬", label: "Asesoría" },
          ].map(badge => (
            <div class="flex flex-col items-center gap-1 p-3 bg-brand-background border border-brand-border rounded-xl text-center">
              <span class="text-base" aria-hidden="true">{badge.icon}</span>
              <span class="text-[9px] font-bold text-brand-secondary leading-tight">{badge.label}</span>
            </div>
          ))}
        </div>

        <AddToCartButton
          client:load
          transition:persist="add-to-cart"
          title={producto.title}
          sku={producto.sku}
          mainImage={producto.mainImage}
          category={producto.category}
        >
          <Button
            variant="whatsapp"
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="whitespace-nowrap"
          >
            <svg class="w-4 h-4 fill-current text-white shrink-0" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
            Contactar
          </Button>
        </AddToCartButton>
      </div>

      <div class="md:col-span-7 flex flex-col gap-6">
        <div class="space-y-3">
          <Badge variant="tag" class="px-3 py-1">{producto.category || 'General'}</Badge>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-brand-primary text-balance leading-tight">
            {producto.title}
          </h1>
          <div class="flex items-center gap-2">
            <span class="text-xs font-mono text-brand-secondary bg-brand-background px-3 py-1.5 rounded-lg border border-brand-border">
              SKU: {producto.sku}
            </span>
          </div>
        </div>

        <div class="border-t border-brand-border pt-5">
          <h2 class="text-[10px] font-black uppercase tracking-widest text-brand-secondary mb-2">Descripción</h2>
          <p class="text-brand-secondary text-sm leading-relaxed">
            {producto.description}
          </p>
        </div>

        {producto.specs && producto.specs.length > 0 && (
          <div class="border-t border-brand-border pt-5">
            <h2 class="text-[10px] font-black uppercase tracking-widest text-brand-secondary mb-3">Especificaciones</h2>
            <div class="overflow-hidden rounded-xl border border-brand-border">
              <table class="w-full text-left text-sm border-collapse">
                <tbody>
                  {producto.specs.map((spec, index) => (
                    <tr class={index % 2 === 0 ? 'bg-brand-background/50' : 'bg-brand-surface'}>
                      <td class="px-4 py-3 font-semibold text-brand-secondary border-r border-brand-border w-2/5 text-xs">
                        {spec?.key}
                      </td>
                      <td class="px-4 py-3 text-brand-primary font-medium text-sm">
                        {spec?.value}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
      </div>
    </article>

    <div class="mt-8">
      <a
        href="/productos"
        class="inline-flex items-center gap-2 text-sm font-semibold text-brand-secondary hover:text-brand-accent transition-colors duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded"
      >
        <Icon name="chevron-left" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform duration-200" />
        Volver al catálogo
      </a>
    </div>
  </main>
</LayoutPrincipal>
