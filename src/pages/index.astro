---
import LayoutPrincipal from '../layouts/LayoutPrincipal.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import Icon from '../components/Icon.astro';
import FeaturedProducts from '../components/vue/FeaturedProducts.vue';
import client from '../../tina/__generated__/client';
import site from '../config/site';

const response = await client.queries.productConnection({ first: 100 });
const allNodes = response.data.productConnection.edges
  ?.map((edge) => edge?.node)
  .filter((node): node is NonNullable<typeof node> => node !== null) ?? [];
const featuredProducts = allNodes.filter((p) => p.featured).slice(0, 3);
---

<LayoutPrincipal
  title={`${site.brand.name} - ${site.brand.tagline}`}
  description={site.brand.description}
>
  <section class="relative overflow-hidden pt-28 pb-24 lg:pt-32 lg:pb-36 bg-gradient-to-br from-brand-surface via-brand-background to-brand-surface">
    <div class="absolute top-1/3 -left-24 w-[500px] h-[500px] rounded-full bg-brand-accent/8 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-purple-500/5 blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10">
      <div class="space-y-7">
        <Badge variant="tag" class="px-4 py-1.5 w-fit flex items-center gap-2">
          <span aria-hidden="true">{site.hero.badge.icon}</span> {site.hero.badge.text}
        </Badge>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-brand-primary leading-[1.05] text-balance">
          {site.hero.title}
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-brand-accent to-purple-500 mt-1">{site.hero.titleAccent}</span>
        </h1>
        <p class="text-brand-secondary text-lg leading-relaxed max-w-lg">
          {site.hero.description}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 pt-2">
          <Button variant="primary" size="lg" href={site.hero.primaryCta.href}>
            {site.hero.primaryCta.label}
          </Button>
          <Button variant="secondary" size="lg" href={site.hero.secondaryCta.href}>
            {site.hero.secondaryCta.label}
          </Button>
        </div>

        <div class="flex gap-8 pt-4 border-t border-brand-border/60">
          {site.hero.stats.map(stat => (
            <div>
              <p class="text-2xl font-black text-brand-primary tabular-nums">{stat.value}</p>
              <p class="text-xs text-brand-secondary font-medium">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="flex justify-center lg:justify-end">
        <div class="relative w-full max-w-lg">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-brand-border aspect-[4/3] bg-brand-surface group">
            <img
              src="/uploads/hero.png"
              alt={`Imagen principal de ${site.brand.name}`}
              width="600"
              height="450"
              fetchpriority="high"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
          </div>
          <div class="absolute -bottom-5 -left-5 bg-brand-surface border border-brand-border rounded-2xl px-5 py-3 shadow-xl flex items-center gap-3">
            <span class="text-2xl" aria-hidden="true">{site.hero.floatingCard.icon}</span>
            <div>
              <p class="text-xs font-black text-brand-primary">{site.hero.floatingCard.title}</p>
              <p class="text-[10px] text-brand-secondary">{site.hero.floatingCard.subtitle}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 border-y border-brand-border bg-brand-surface/60" aria-labelledby="categories-heading">
    <div class="max-w-6xl mx-auto px-6">
      <h2 id="categories-heading" class="sr-only">Categorías</h2>
      <p class="text-center text-xs font-black uppercase tracking-widest text-brand-secondary mb-8">Categorías destacadas</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
        {site.categories.map(cat => (
          <a
            href={cat.href}
            class="flex flex-col items-center gap-2 p-4 rounded-2xl border border-brand-border bg-brand-background hover:border-brand-accent/40 hover:bg-brand-surface hover:shadow-sm text-center transition-all duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50"
          >
            <span class="text-2xl group-hover:scale-110 transition-transform duration-200" aria-hidden="true">{cat.icon}</span>
            <span class="text-[10px] font-bold text-brand-secondary group-hover:text-brand-accent transition-colors duration-200 leading-tight">{cat.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 max-w-6xl mx-auto px-6" aria-labelledby="featured-heading">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-12 gap-4">
      <div>
        <span class="text-xs font-black tracking-widest uppercase text-brand-accent">Destacados</span>
        <h2 id="featured-heading" class="text-3xl sm:text-4xl font-extrabold text-brand-primary mt-1 text-balance">Selección principal</h2>
      </div>
      <Button variant="link" href="/productos">
        Ver todo el catálogo
        <Icon name="chevron-right" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" />
      </Button>
    </div>

    {featuredProducts.length > 0 ? (
      <FeaturedProducts client:load productos={featuredProducts} />
    ) : (
      <div class="text-center py-16 text-brand-secondary text-sm bg-brand-surface border border-brand-border rounded-2xl">
        Aún no hay productos destacados. Crea uno desde el panel de TinaCMS.
      </div>
    )}
  </section>

  <section class="py-16 bg-brand-surface border-t border-brand-border" aria-labelledby="why-heading">
    <h2 id="why-heading" class="sr-only">Características</h2>
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        {site.ctaStrip.map(item => (
          <div class="space-y-3 p-6 rounded-2xl hover:bg-brand-background transition-colors duration-200">
            <span class="text-3xl block" aria-hidden="true">{item.icon}</span>
            <h3 class="font-extrabold text-brand-primary text-base">{item.title}</h3>
            <p class="text-brand-secondary text-sm leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 max-w-6xl mx-auto px-6">
    <div class="bg-gradient-to-br from-brand-accent via-brand-accent to-purple-600 rounded-3xl p-10 md:p-16 text-white relative overflow-hidden shadow-xl shadow-brand-accent/20">
      <div class="absolute -top-16 -left-16 w-64 h-64 rounded-full bg-white/5 blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="absolute -bottom-16 -right-16 w-64 h-64 rounded-full bg-white/5 blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="relative z-10 max-w-2xl mx-auto text-center space-y-6">
        <h2 class="text-3xl md:text-4xl font-extrabold leading-tight text-balance">
          {site.ctaBanner.title}
        </h2>
        <p class="text-white/80 text-sm md:text-base leading-relaxed">
          {site.ctaBanner.description}
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4 pt-2">
          <Button variant="secondary" size="lg" href={site.ctaBanner.primaryCta.href} class="bg-white text-brand-accent hover:bg-slate-50 focus-visible:ring-white/60">
            {site.ctaBanner.primaryCta.label}
          </Button>
          <Button variant="primary" size="lg" href={site.ctaBanner.secondaryCta.href} class="bg-transparent border border-white/25 hover:bg-white/10 text-white focus-visible:ring-white/40">
            {site.ctaBanner.secondaryCta.label}
          </Button>
        </div>
      </div>
    </div>
  </section>
</LayoutPrincipal>
