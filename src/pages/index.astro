---
import LayoutPrincipal from '../layouts/LayoutPrincipal.astro';
import client from '../../tina/__generated__/client';

const response = await client.queries.productConnection();
const allProducts = response.data.productConnection.edges?.map((edge) => edge?.node) || [];
const featuredProducts = allProducts.filter((product) => product.featured).slice(0, 3);
---

<LayoutPrincipal 
  title="Distribuidora de Plásticos y Desechables - Catálogo" 
  description="Tu aliado en productos plásticos y desechables. Vasos, platos, cubiertos, envases, bolsas y más. Calidad y variedad para tu negocio."
>
  <!-- 1. HERO SECTION -->
  <section class="relative overflow-hidden py-24 lg:py-36 bg-gradient-to-br from-brand-surface via-brand-background to-brand-surface">
    <!-- Decorative blobs -->
    <div class="absolute top-1/3 -left-24 w-[500px] h-[500px] rounded-full bg-brand-accent/8 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-purple-500/5 blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10">
      <!-- Left text -->
      <div class="space-y-7">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest text-brand-accent bg-brand-accent/10 border border-brand-accent/20 w-fit">
          🏭 Distribuidora Mayorista
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tight text-brand-primary leading-[1.05] text-balance">
          Plásticos y Desechables
          <span class="block text-transparent bg-clip-text bg-gradient-to-r from-brand-accent to-purple-500 mt-1">para tu Negocio</span>
        </h1>
        <p class="text-brand-secondary text-lg leading-relaxed max-w-lg">
          Vasos, platos, cubiertos, envases, bolsas y artículos de higiene. Todo lo que tu restaurante, evento o empresa necesita con la mejor calidad y precio mayorista.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 pt-2">
          <a
            href="/productos"
            class="px-8 py-4 rounded-xl bg-brand-accent text-white font-extrabold text-center shadow-lg shadow-brand-accent/25 hover:shadow-xl hover:bg-brand-accent/90 hover:-translate-y-0.5 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/60"
          >
            Ver Catálogo Completo
          </a>
          <a
            href="/contacto"
            class="px-8 py-4 rounded-xl border border-brand-border bg-brand-surface text-brand-primary font-extrabold text-center hover:bg-brand-background transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/40"
          >
            Solicitar Cotización
          </a>
        </div>

        <!-- Quick stats -->
        <div class="flex gap-8 pt-4 border-t border-brand-border/60">
          <div>
            <p class="text-2xl font-black text-brand-primary tabular-nums">+200</p>
            <p class="text-xs text-brand-secondary font-medium">Productos</p>
          </div>
          <div>
            <p class="text-2xl font-black text-brand-primary tabular-nums">7</p>
            <p class="text-xs text-brand-secondary font-medium">Categorías</p>
          </div>
          <div>
            <p class="text-2xl font-black text-brand-primary tabular-nums">24h</p>
            <p class="text-xs text-brand-secondary font-medium">Entrega</p>
          </div>
        </div>
      </div>

      <!-- Right image -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative w-full max-w-lg">
          <!-- Main card -->
          <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-brand-border aspect-[4/3] bg-brand-surface group">
            <img
              src="/uploads/hero-artwork.png"
              alt="Variedad de productos plásticos y desechables de distribuidora"
              width="600"
              height="450"
              fetchpriority="high"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-surface/30 to-transparent pointer-events-none" aria-hidden="true"></div>
          </div>
          <!-- Floating badge -->
          <div class="absolute -bottom-5 -left-5 bg-brand-surface border border-brand-border rounded-2xl px-5 py-3 shadow-xl flex items-center gap-3">
            <span class="text-2xl" aria-hidden="true">♻️</span>
            <div>
              <p class="text-xs font-black text-brand-primary">Eco-friendly</p>
              <p class="text-[10px] text-brand-secondary">Opciones biodegradables</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CATEGORIES STRIP -->
  <section class="py-14 border-y border-brand-border bg-brand-surface/60">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-center text-xs font-black uppercase tracking-widest text-brand-secondary mb-8">Nuestras Categorías</p>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
        {[
          { icon: "🥤", label: "Vasos y Copas", href: "/productos" },
          { icon: "🍽️", label: "Platos y Bandejas", href: "/productos" },
          { icon: "🍴", label: "Cubiertos", href: "/productos" },
          { icon: "📦", label: "Envases", href: "/productos" },
          { icon: "🛍️", label: "Bolsas", href: "/productos" },
          { icon: "🧹", label: "Higiene", href: "/productos" },
          { icon: "🔧", label: "Otros", href: "/productos" },
        ].map(cat => (
          <a
            href={cat.href}
            class="flex flex-col items-center gap-2 p-4 rounded-2xl border border-brand-border bg-brand-background hover:border-brand-accent/40 hover:bg-brand-surface hover:shadow-sm text-center transition-all duration-200 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50"
          >
            <span class="text-2xl group-hover:scale-110 transition-transform duration-200" aria-hidden="true">{cat.icon}</span>
            <span class="text-[10px] font-bold text-brand-secondary group-hover:text-brand-accent transition-colors duration-200 leading-tight">{cat.label}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. FEATURED PRODUCTS -->
  <section class="py-20 max-w-6xl mx-auto px-6">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between mb-12 gap-4">
      <div>
        <span class="text-xs font-black tracking-widest uppercase text-brand-accent">Productos Destacados</span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-primary mt-1 text-balance">Nuestra Selección Principal</h2>
      </div>
      <a
        href="/productos"
        class="inline-flex items-center gap-1.5 text-sm font-bold text-brand-accent hover:text-brand-accent/70 transition-colors duration-200 shrink-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded group"
      >
        Ver todo el catálogo
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </a>
    </div>

    {featuredProducts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProducts.map((producto) => (
          <article class="group bg-brand-surface border border-brand-border hover:border-brand-accent/25 rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col">
            <!-- Image -->
            <div class="relative overflow-hidden bg-brand-background aspect-[4/3]">
              {producto.mainImage ? (
                <img
                  src={producto.mainImage}
                  alt={producto.title}
                  width="400"
                  height="300"
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-brand-secondary/20" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-14 h-14">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375 0 11-.75 0 .375 0 01.75 0z" />
                  </svg>
                </div>
              )}
              <span class="absolute bottom-3 right-3 bg-brand-surface/80 backdrop-blur-sm text-brand-accent text-[9px] font-black tracking-widest uppercase px-2.5 py-1 rounded-md border border-brand-border/50">
                {producto.category || 'General'}
              </span>
            </div>
            <!-- Body -->
            <div class="flex flex-col flex-grow p-5">
              <h3 class="text-base font-extrabold text-brand-primary group-hover:text-brand-accent transition-colors duration-200 leading-snug text-pretty">
                {producto.title}
              </h3>
              <p class="text-brand-secondary text-xs mt-2 line-clamp-2 leading-relaxed flex-grow">
                {producto.description}
              </p>
              <div class="flex items-center justify-between pt-4 mt-4 border-t border-brand-border/60">
                <span class="text-[10px] text-brand-secondary/60 font-mono min-w-0 truncate mr-2">SKU: {producto.sku}</span>
                <a
                  href={`/productos/${producto._sys.relativePath.replace(/\.json$/, '')}`}
                  class="inline-flex items-center gap-1 text-xs font-bold text-brand-accent hover:text-brand-accent/70 transition-colors duration-200 shrink-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent/50 rounded"
                >
                  Ver ficha
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-16 text-brand-secondary text-sm bg-brand-surface border border-brand-border rounded-2xl">
        No hay productos destacados configurados aún.
      </div>
    )}
  </section>

  <!-- 4. WHY US STRIP -->
  <section class="py-16 bg-brand-surface border-t border-brand-border">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
        {[
          { icon: "🚚", title: "Entrega Rápida", desc: "Despacho en 24 horas hábiles a todo el país" },
          { icon: "💰", title: "Precios Mayoristas", desc: "Las mejores tarifas del mercado para empresas" },
          { icon: "🤝", title: "Asesoría Personalizada", desc: "Te ayudamos a elegir el producto ideal para tu negocio" },
        ].map(item => (
          <div class="space-y-3 p-6 rounded-2xl hover:bg-brand-background transition-colors duration-200">
            <span class="text-3xl block" aria-hidden="true">{item.icon}</span>
            <h3 class="font-extrabold text-brand-primary text-base">{item.title}</h3>
            <p class="text-brand-secondary text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. CTA BANNER -->
  <section class="py-20 max-w-6xl mx-auto px-6">
    <div class="bg-gradient-to-br from-brand-accent via-brand-accent to-purple-600 rounded-3xl p-10 md:p-16 text-white relative overflow-hidden shadow-xl shadow-brand-accent/20">
      <div class="absolute -top-16 -left-16 w-64 h-64 rounded-full bg-white/5 blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="absolute -bottom-16 -right-16 w-64 h-64 rounded-full bg-white/5 blur-3xl pointer-events-none" aria-hidden="true"></div>
      <div class="relative z-10 max-w-2xl mx-auto text-center space-y-6">
        <h2 class="text-3xl md:text-4xl font-extrabold leading-tight text-balance">
          ¿Necesitas cotización para tu empresa?
        </h2>
        <p class="text-white/80 text-sm md:text-base leading-relaxed">
          Atendemos pedidos al por mayor con precios especiales para distribuidores, restaurantes, eventos y comercios.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4 pt-2">
          <a
            href="/contacto"
            class="px-8 py-4 rounded-xl bg-white text-brand-accent font-extrabold shadow-lg hover:bg-slate-50 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/60"
          >
            Contactar Ahora
          </a>
          <a
            href="/productos"
            class="px-8 py-4 rounded-xl border border-white/25 hover:bg-white/10 text-white font-extrabold transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
          >
            Ver Productos
          </a>
        </div>
      </div>
    </div>
  </section>
</LayoutPrincipal>