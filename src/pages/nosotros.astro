---
import LayoutPrincipal from '../layouts/LayoutPrincipal.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import site from '../config/site';
const { about } = site;
---

<LayoutPrincipal
  title={`${about.title} - ${site.brand.name}`}
  description={`Conoce más sobre ${site.brand.name}: nuestra historia, misión y valores.`}
>
  <main class="max-w-5xl mx-auto py-16 px-6 space-y-24">
    <header class="text-center max-w-2xl mx-auto space-y-5">
      <span class="inline-block text-xs font-black tracking-widest uppercase text-brand-accent px-4 py-1.5 bg-brand-accent/10 border border-brand-accent/20 rounded-full">
        {about.badge}
      </span>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight text-brand-primary text-balance">
        {about.title}
      </h1>
      <p class="text-brand-secondary text-lg leading-relaxed">
        {about.intro}
      </p>
    </header>

    <section aria-labelledby="story-heading">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">
        <div class="space-y-5">
          <h2 id="story-heading" class="text-3xl font-extrabold text-brand-primary leading-tight text-balance">
            Una historia que vale la pena contar
          </h2>
          {about.body.map(p => (
            <p class="text-brand-secondary leading-relaxed">{p}</p>
          ))}
          <div class="grid grid-cols-3 gap-4 pt-4 border-t border-brand-border/60">
            {about.stats.map(stat => (
              <div class="text-center">
                <p class="text-2xl font-black text-brand-accent tabular-nums">{stat.value}</p>
                <p class="text-[10px] text-brand-secondary font-medium mt-0.5 leading-tight">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-brand-surface border border-brand-border rounded-2xl p-7 space-y-6 shadow-sm">
          <div class="space-y-2">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-brand-accent/10 flex items-center justify-center text-base" aria-hidden="true">{about.mission.icon}</div>
              <span class="text-xs font-black uppercase tracking-widest text-brand-accent">{about.mission.label}</span>
            </div>
            <p class="text-brand-primary text-sm leading-relaxed">
              {about.mission.text}
            </p>
          </div>
          <hr class="border-brand-border" />
          <div class="space-y-2">
            <div class="flex items-center gap-2 mb-3">
              <div class="w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center text-base" aria-hidden="true">{about.vision.icon}</div>
              <span class="text-xs font-black uppercase tracking-widest text-purple-500">{about.vision.label}</span>
            </div>
            <p class="text-brand-primary text-sm leading-relaxed">
              {about.vision.text}
            </p>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="values-heading">
      <div class="text-center max-w-xl mx-auto mb-10">
        <span class="text-xs font-black tracking-widest uppercase text-brand-accent">Pilares</span>
        <h2 id="values-heading" class="text-2xl sm:text-3xl font-extrabold text-brand-primary mt-1 text-balance">
          {about.pillarsTitle}
        </h2>
        <p class="text-brand-secondary text-sm mt-2">{about.pillarsSubtitle}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {about.pillars.map(val => (
          <div class="bg-brand-surface border border-brand-border rounded-2xl p-6 space-y-3 hover:shadow-md hover:border-brand-accent/20 transition-all duration-300">
            <div class={`w-10 h-10 rounded-xl ${val.color} flex items-center justify-center text-xl`} aria-hidden="true">{val.icon}</div>
            <h3 class="font-extrabold text-base text-brand-primary">{val.title}</h3>
            <p class="text-brand-secondary text-sm leading-relaxed">{val.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="text-center bg-gradient-to-br from-brand-accent/8 to-purple-500/5 border border-brand-border rounded-3xl p-10 space-y-5">
      <h2 class="text-2xl font-extrabold text-brand-primary text-balance">{about.cta.title}</h2>
      <p class="text-brand-secondary text-sm max-w-md mx-auto leading-relaxed">{about.cta.description}</p>
      <Button variant="primary" size="lg" href={about.cta.ctaHref}>
        {about.cta.ctaLabel}
        <Icon name="chevron-right" class="w-4 h-4" />
      </Button>
    </section>
  </main>
</LayoutPrincipal>
